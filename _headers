# GitHub Pages per-file cache control
# HTML: never cache (always get fresh version references)
/*.html
  Cache-Control: no-cache, must-revalidate

# Root-level files
/*
  Cache-Control: no-cache, must-revalidate

# CSS/JS: cache but use ?v=N for busting
/assets/*
  Cache-Control: public, max-age=31536000, immutable
